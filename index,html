<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Widget Library</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #111111; color: #ffffff; font-family: sans-serif; padding: 40px 24px; }
    h1 { font-size: 22px; font-weight: 700; color: #ff8c00; margin-bottom: 8px; }
    p { font-size: 14px; color: #888888; margin-bottom: 32px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px; }
    a.card {
      background: #1c1c1c;
      border: 1px solid #2e2e2e;
      border-radius: 10px;
      padding: 20px 16px;
      text-decoration: none;
      color: #ffffff;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      transition: border-color 0.2s;
    }
    a.card:hover { border-color: #ff8c00; }
    a.card .icon { font-size: 28px; }
    a.card .label { font-size: 15px; font-weight: 700; }
    a.card .desc { font-size: 12px; color: #888888; text-align: center; }
  </style>
</head>
<body>
  <h1>Widget Library</h1>
  <p>Corsair Xenon Edge widgets by chadporter33</p>
  <div class="grid">
    <a class="card" href="calculator.html">
      <div class="icon">&#8801;</div>
      <div class="label">Calculator</div>
      <div class="desc">Basic arithmetic widget</div>
    </a>
  </div>
</body>
</html>
